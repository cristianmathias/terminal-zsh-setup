# Packages documented in terminal-zsh-guide.md for Ubuntu/Linuxbrew.
# Nerd Font is installed by install-terminal-zsh-setup-ubuntu.sh because
# Homebrew casks are macOS-only.

brew "atuin"
brew "bat"
brew "direnv"
brew "eza"
brew "fd"
brew "fzf"
brew "git-delta"
brew "lazygit"
brew "ripgrep"
brew "starship"
brew "zoxide"
brew "zsh-autosuggestions"
brew "zsh-completions"
brew "zsh-syntax-highlighting"
